<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_mobile_order" model="ir.ui.view">
        <field name="name">res.company.form.mobile.order</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="Mobile app" name="mobile_app_company" groups="sales_team.group_sale_manager">
                    <group>
                        <field name="mobile_pos_config_id" options="{'no_create': True}"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
