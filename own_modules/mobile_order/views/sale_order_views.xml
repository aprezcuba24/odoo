<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_mobile_order" model="ir.ui.view">
        <field name="name">sale.order.form.mobile.order</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='sale_header']" position="after">
                <group name="mobile_order_info" string="Mobile" groups="sales_team.group_sale_salesman">
                    <field name="mobile_origin"/>
                    <field name="mobile_order_ref" readonly="1"/>
                    <field name="mobile_device_id" options="{'no_create': True}"/>
                    <field name="mobile_device_validated" readonly="1"/>
                    <field name="mobile_pos_config_id" options="{'no_create': True}" invisible="not mobile_pos_config_id"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_order_tree_mobile_order" model="ir.ui.view">
        <field name="name">sale.order.list.mobile.order</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="mobile_origin" optional="hide"/>
                <field name="mobile_order_ref" optional="hide"/>
                <field name="mobile_device_validated" optional="hide" string="Mobile dev. OK"/>
            </xpath>
        </field>
    </record>

    <record id="view_quotation_tree_mobile_order" model="ir.ui.view">
        <field name="name">sale.order.quotation.list.mobile.order</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="mobile_origin" optional="hide"/>
                <field name="mobile_order_ref" optional="hide"/>
                <field name="mobile_device_validated" optional="hide" string="Mobile dev. OK"/>
            </xpath>
        </field>
    </record>
</odoo>
