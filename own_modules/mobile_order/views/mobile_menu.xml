<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_mobile_sale_orders" model="ir.actions.act_window">
        <field name="name">Mobile sales orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form,calendar,graph,pivot</field>
        <field name="domain">[('mobile_origin', '!=', False)]</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="sale.view_sales_order_filter"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No mobile orders yet.</p>
            <p>Orders created from the mobile app or marked as mobile (admin) appear here.</p>
        </field>
    </record>

    <record id="action_mobile_partners" model="ir.actions.act_window">
        <field name="name">Mobile customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('mobile_app_registered', '=', True)]</field>
        <field name="context">{'default_customer_rank': 1}</field>
        <field name="search_view_id" ref="base.view_res_partner_filter"/>
    </record>

    <menuitem
        id="menu_mobile_order_root"
        name="Mobile"
        parent="sale.sale_menu_root"
        sequence="26"
        groups="sales_team.group_sale_salesman"/>

    <menuitem
        id="menu_mobile_devices"
        name="Devices"
        parent="menu_mobile_order_root"
        action="action_mobile_device"
        sequence="10"
        groups="sales_team.group_sale_salesman"/>

    <menuitem
        id="menu_mobile_orders"
        name="Mobile orders"
        parent="menu_mobile_order_root"
        action="action_mobile_sale_orders"
        sequence="20"
        groups="sales_team.group_sale_salesman"/>

    <menuitem
        id="menu_mobile_customers"
        name="Mobile customers"
        parent="menu_mobile_order_root"
        action="action_mobile_partners"
        sequence="30"
        groups="sales_team.group_sale_salesman"/>
</odoo>
