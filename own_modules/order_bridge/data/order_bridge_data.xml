<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_order_bridge_ref" model="ir.sequence">
        <field name="name">Order bridge reference</field>
        <field name="code">order_bridge.order.ref</field>
        <field name="prefix">OB-</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="ir_config_parameter_order_bridge_inactivity_days" model="ir.config_parameter">
        <field name="key">order_bridge.device_inactivity_days</field>
        <field name="value">90</field>
    </record>

    <record id="ir_cron_order_bridge_device_inactive" model="ir.cron">
        <field name="name">Order bridge: deactivate inactive devices</field>
        <field name="model_id" ref="order_bridge.model_order_bridge_device"/>
        <field name="state">code</field>
        <field name="code">model.cron_deactivate_inactive_devices()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
