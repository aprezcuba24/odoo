<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_bridge_fcm_send_wizard_form" model="ir.ui.view">
        <field name="name">order_bridge.fcm.send.wizard.form</field>
        <field name="model">order_bridge.fcm.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Enviar notificación push FCM">
                <group>
                    <field name="target_mode" widget="radio" options="{'horizontal': true}"/>
                    <field name="partner_id" invisible="target_mode != 'single_partner'"/>
                    <field
                        name="partner_ids"
                        widget="many2many_tags"
                        invisible="target_mode != 'multi_partner'"
                    />
                    <field
                        name="fcm_topic"
                        placeholder="com_culabs_odooshop_all"
                        invisible="target_mode != 'topic'"
                    />
                </group>
                <group>
                    <field name="title" placeholder="Título visible"/>
                    <field name="body" placeholder="Texto de la notificación"/>
                </group>
                <group>
                    <field name="data_json" placeholder="{}"/>
                </group>
                <footer>
                    <button name="action_send" string="Enviar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_order_bridge_fcm_send_wizard" model="ir.actions.act_window">
        <field name="name">Enviar notificación push</field>
        <field name="res_model">order_bridge.fcm.send.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_order_bridge_fcm_send_wizard_form"/>
    </record>

    <record id="action_order_bridge_fcm_send_wizard_from_partners" model="ir.actions.act_window">
        <field name="name">Enviar notificación push a contactos</field>
        <field name="res_model">order_bridge.fcm.send.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_order_bridge_fcm_send_wizard_form"/>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_view_types">list</field>
        <field name="context">{'default_target_mode': 'multi_partner'}</field>
    </record>
</odoo>
