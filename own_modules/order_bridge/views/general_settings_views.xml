<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_bridge_general_settings_tree" model="ir.ui.view">
        <field name="name">order_bridge.general_settings.list</field>
        <field name="model">order_bridge.general_settings</field>
        <field name="arch" type="xml">
            <list string="Datos generales Tienda Apk" create="false" delete="false">
                <field name="company_id"/>
                <field name="shop_phone"/>
            </list>
        </field>
    </record>

    <record id="view_order_bridge_general_settings_form" model="ir.ui.view">
        <field name="name">order_bridge.general_settings.form</field>
        <field name="model">order_bridge.general_settings</field>
        <field name="arch" type="xml">
            <form string="Datos generales Tienda Apk" create="false" delete="false">
                <sheet>
                    <group>
                        <field name="company_id" readonly="1"/>
                        <field name="shop_phone" placeholder="Ej. +34 900 000 000"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_order_bridge_general_settings" model="ir.actions.act_window">
        <field name="name">Datos generales</field>
        <field name="res_model">order_bridge.general_settings</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Teléfono y otros datos generales de la tienda para la aplicación.</p>
        </field>
    </record>
</odoo>
