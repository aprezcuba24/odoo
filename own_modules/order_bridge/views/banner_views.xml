<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_bridge_banner_tree" model="ir.ui.view">
        <field name="name">order_bridge.banner.list</field>
        <field name="model">order_bridge.banner</field>
        <field name="arch" type="xml">
            <list string="Banners publicitarios">
                <field name="sequence" widget="handle"/>
                <field name="title"/>
                <field name="subtitle" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="bg_color" optional="hide"/>
                <field name="text_color" optional="hide"/>
                <field name="active" widget="boolean"/>
            </list>
        </field>
    </record>

    <record id="view_order_bridge_banner_form" model="ir.ui.view">
        <field name="name">order_bridge.banner.form</field>
        <field name="model">order_bridge.banner</field>
        <field name="arch" type="xml">
            <form string="Banner publicitario">
                <sheet>
                    <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <field name="title"/>
                        <field name="subtitle"/>
                        <field name="href"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <group string="Colores">
                        <field name="bg_color" widget="color"/>
                        <field name="text_color" widget="color"/>
                    </group>
                    <group string="Imagen">
                        <field name="image" widget="image" class="oe_avatar o_image_small"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_order_bridge_banner_search" model="ir.ui.view">
        <field name="name">order_bridge.banner.search</field>
        <field name="model">order_bridge.banner</field>
        <field name="arch" type="xml">
            <search string="Banners">
                <field name="title"/>
                <field name="subtitle"/>
                <filter name="active" string="Activos" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Archivados" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_order_bridge_banner" model="ir.actions.act_window">
        <field name="name">Banners publicitarios</field>
        <field name="res_model">order_bridge.banner</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_order_bridge_banner_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Cree banners para la tienda en la aplicación.</p>
        </field>
    </record>
</odoo>
