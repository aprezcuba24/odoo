<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_order_bridge" model="ir.ui.view">
        <field name="name">product.template.form.order.bridge</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-flex" groups="sales_team.group_sale_salesman">
                    <field name="order_bridge_visible"/>
                    <label for="order_bridge_visible"/>
                </span>
            </xpath>
        </field>
    </record>

    <record id="product_template_tree_view_order_bridge" model="ir.ui.view">
        <field name="name">product.template.list.order.bridge</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="order_bridge_visible" optional="hide" groups="sales_team.group_sale_salesman"/>
            </xpath>
        </field>
    </record>
</odoo>
