<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_bridge_device_tree" model="ir.ui.view">
        <field name="name">order_bridge.device.list</field>
        <field name="model">order_bridge.device</field>
        <field name="arch" type="xml">
            <list string="Dispositivos API" decoration-muted="not active" decoration-warning="active and not phone_validated">
                <field name="phone"/>
                <field name="partner_id"/>
                <field name="phone_validated" widget="boolean"/>
                <field name="active" widget="boolean"/>
                <field name="registration_date"/>
                <field name="last_activity"/>
                <field name="device_key" optional="hide"/>
                <field name="device_info" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_order_bridge_device_form" model="ir.ui.view">
        <field name="name">order_bridge.device.form</field>
        <field name="model">order_bridge.device</field>
        <field name="arch" type="xml">
            <form string="Dispositivo API">
                <header>
                    <button name="action_validate_phone" type="object" string="Validar teléfono" class="btn-primary" invisible="phone_validated"/>
                    <button name="action_revoke_validation" type="object" string="Revocar validación" invisible="not phone_validated"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archivado" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="device_key" password="True"/>
                            <field name="phone"/>
                            <field name="phone_validated"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="registration_date"/>
                            <field name="last_activity"/>
                            <field name="device_info"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_order_bridge_device_search" model="ir.ui.view">
        <field name="name">order_bridge.device.search</field>
        <field name="model">order_bridge.device</field>
        <field name="arch" type="xml">
            <search string="Dispositivos API">
                <field name="phone"/>
                <field name="partner_id"/>
                <field name="device_key"/>
                <separator/>
                <filter name="filter_pending" string="Pendiente de validación" domain="[('phone_validated', '=', False), ('active', '=', True)]"/>
                <filter name="filter_validated" string="Validado" domain="[('phone_validated', '=', True), ('active', '=', True)]"/>
                <filter name="filter_inactive" string="Inactivo" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_order_bridge_device" model="ir.actions.act_window">
        <field name="name">Dispositivos API</field>
        <field name="res_model">order_bridge.device</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_order_bridge_device_search"/>
        <field name="context">{'search_default_filter_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registre y valide los dispositivos de los clientes para la API de Tienda Apk.</p>
        </field>
    </record>
</odoo>
