<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_order_bridge" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.order_bridge</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='point_of_sale']/div[@class='pos_res_config_container']" position="before">
                <block title="Order bridge" id="order_bridge_pos_settings_block">
                    <setting
                        string="Order bridge point of sale"
                        help="The order bridge catalog uses the same products as this point of sale (availability and category restrictions)."
                    >
                        <field name="order_bridge_pos_config_id" options="{'no_create': True}"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
