<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_order_bridge" model="ir.module.category">
        <field name="name">Order bridge</field>
        <field name="description">Manage API client devices and bridge-related sales</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_order_bridge_user" model="res.groups">
        <field name="name">Order bridge user</field>
        <field name="category_id" ref="module_category_order_bridge"/>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="group_order_bridge_manager" model="res.groups">
        <field name="name">Order bridge manager</field>
        <field name="category_id" ref="module_category_order_bridge"/>
        <field name="implied_ids" eval="[(4, ref('group_order_bridge_user')), (4, ref('sales_team.group_sale_manager'))]"/>
    </record>
</odoo>
