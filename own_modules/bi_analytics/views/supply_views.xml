<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bi_supply_list" model="ir.ui.view">
        <field name="name">bi.supply.list</field>
        <field name="model">bi.supply</field>
        <field name="arch" type="xml">
            <list string="Insumos">
                <field name="name"/>
                <field name="unit"/>
                <field name="cost"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_bi_supply_form" model="ir.ui.view">
        <field name="name">bi.supply.form</field>
        <field name="model">bi.supply</field>
        <field name="arch" type="xml">
            <form string="Insumo">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="unit"/>
                            <field name="cost"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bi_supply_search" model="ir.ui.view">
        <field name="name">bi.supply.search</field>
        <field name="model">bi.supply</field>
        <field name="arch" type="xml">
            <search string="Insumos">
                <field name="name"/>
                <field name="unit"/>
                <filter name="filter_active" string="Activos" domain="[('active', '=', True)]"/>
                <filter name="filter_archived" string="Archivados" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Compañía" name="groupby_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bi_supply" model="ir.actions.act_window">
        <field name="name">Insumos</field>
        <field name="res_model">bi.supply</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bi_supply_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea insumos para registrar materias primas y otros gastos de consumo.</p>
            <p>Define el nombre, la unidad de medida y el costo unitario. Luego regístralos en <b>Otros costos</b> con la categoría Insumo.</p>
        </field>
    </record>
</odoo>
