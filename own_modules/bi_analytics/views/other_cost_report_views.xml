<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bi_other_cost_report_list" model="ir.ui.view">
        <field name="name">bi.other.cost.report.list</field>
        <field name="model">bi.other.cost.report</field>
        <field name="arch" type="xml">
            <list string="Reportes de gastos" default_group_by="category_id">
                <field name="category_id"/>
                <field name="cost_type" optional="show"/>
                <field name="product_id" optional="show"/>
                <field name="name"/>
                <field name="amount" sum="Importe total"/>
                <field name="date" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_bi_other_cost_report_search" model="ir.ui.view">
        <field name="name">bi.other.cost.report.search</field>
        <field name="model">bi.other.cost.report</field>
        <field name="arch" type="xml">
            <search string="Reportes de gastos">
                <field name="name"/>
                <field name="category_id"/>
                <field name="product_id"/>
                <filter name="filter_date" date="date" default_period="month"/>
                <group>
                    <filter string="Categoría" name="groupby_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Tipo de costo" name="groupby_cost_type" context="{'group_by': 'cost_type'}"/>
                    <filter string="Insumo" name="groupby_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Compañía" name="groupby_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                    <filter string="Fecha" name="groupby_date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bi_other_cost_report" model="ir.actions.act_window">
        <field name="name">Reportes de gastos</field>
        <field name="res_model">bi.other.cost.report</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_bi_other_cost_report_search"/>
        <field name="context">{'search_default_groupby_category': 1, 'search_default_filter_date': 1, 'expand': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aún no hay gastos confirmados.</p>
            <p>Este reporte muestra por categoría los importes de gastos confirmados. Por defecto se filtra por el mes actual.</p>
        </field>
    </record>
</odoo>
