<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bi_supply_entry_list" model="ir.ui.view">
        <field name="name">bi.supply.entry.list</field>
        <field name="model">bi.supply.entry</field>
        <field name="arch" type="xml">
            <list string="Entradas de insumos">
                <field name="date"/>
                <field name="supply_id"/>
                <field name="quantity"/>
                <field name="unit_cost"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_bi_supply_entry_form" model="ir.ui.view">
        <field name="name">bi.supply.entry.form</field>
        <field name="model">bi.supply.entry</field>
        <field name="arch" type="xml">
            <form string="Entrada de insumo">
                <sheet>
                    <group>
                        <group>
                            <field name="supply_id"/>
                            <field name="date"/>
                            <field name="quantity"/>
                            <field name="unit_cost"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bi_supply_entry_search" model="ir.ui.view">
        <field name="name">bi.supply.entry.search</field>
        <field name="model">bi.supply.entry</field>
        <field name="arch" type="xml">
            <search string="Entradas de insumos">
                <field name="supply_id"/>
                <filter name="filter_date" date="date" default_period="month"/>
                <group>
                    <filter string="Insumo" name="groupby_supply" context="{'group_by': 'supply_id'}"/>
                    <filter string="Fecha" name="groupby_date" context="{'group_by': 'date:month'}"/>
                    <filter string="Compañía" name="groupby_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bi_supply_entry" model="ir.actions.act_window">
        <field name="name">Entrada de insumos</field>
        <field name="res_model">bi.supply.entry</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bi_supply_entry_search"/>
        <field name="context">{'search_default_filter_date': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registra entradas de insumos para actualizar el stock y el costo promedio.</p>
            <p>Indica la cantidad recibida, el precio de costo unitario y la fecha de entrada.</p>
        </field>
    </record>
</odoo>
