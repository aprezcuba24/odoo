<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bi_cost_category_list" model="ir.ui.view">
        <field name="name">bi.cost.category.list</field>
        <field name="model">bi.cost.category</field>
        <field name="arch" type="xml">
            <list string="Categorías de costo" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="cost_type"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_bi_cost_category_form" model="ir.ui.view">
        <field name="name">bi.cost.category.form</field>
        <field name="model">bi.cost.category</field>
        <field name="arch" type="xml">
            <form string="Categoría de costo">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="cost_type"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bi_cost_category" model="ir.actions.act_window">
        <field name="name">Categoría</field>
        <field name="res_model">bi.cost.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
