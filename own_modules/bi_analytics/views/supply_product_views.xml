<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bi_supply_product_template_list" model="ir.ui.view">
        <field name="name">product.template.supply.list</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="Insumos">
                <field name="name"/>
                <field name="categ_id"/>
                <field name="qty_available" string="En mano" optional="show" groups="stock.group_stock_user"/>
                <field name="standard_price"/>
                <field name="uom_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_bi_supply_product_template_form" model="ir.ui.view">
        <field name="name">product.template.supply.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <field name="sale_ok" position="attributes">
                <attribute name="readonly">1</attribute>
            </field>
            <field name="purchase_ok" position="attributes">
                <attribute name="readonly">1</attribute>
            </field>
        </field>
    </record>

    <record id="action_bi_supply_product" model="ir.actions.act_window">
        <field name="name">Insumos</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_bi_supply_product_template_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_bi_supply_product_template_form')}),
        ]"/>
        <field name="domain">[('sale_ok', '=', False), ('purchase_ok', '=', True), ('is_storable', '=', True)]</field>
        <field name="context" eval="{
            'default_sale_ok': False,
            'default_purchase_ok': True,
            'default_type': 'consu',
            'default_is_storable': True,
            'default_categ_id': ref('bi_analytics.product_category_supplies'),
        }"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea insumos para registrar materias primas y otros productos no vendibles.</p>
            <p>Los insumos se compran en <b>Compras de insumos</b>, se consultan en <b>Existencias de insumos</b> y su consumo se registra en <b>Consumo de insumos</b>.</p>
        </field>
    </record>
</odoo>
