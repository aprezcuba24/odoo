<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bi_profitability_report_list" model="ir.ui.view">
        <field name="name">bi.profitability.report.list</field>
        <field name="model">bi.profitability.report</field>
        <field name="arch" type="xml">
            <list string="Resumen de rentabilidad">
                <field name="date"/>
                <field name="sale_amount" sum="Total ventas"/>
                <field name="product_cost_amount" sum="Total costo de productos"/>
                <field name="gross_profit_amount" sum="Total margen bruto"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_bi_profitability_report_search" model="ir.ui.view">
        <field name="name">bi.profitability.report.search</field>
        <field name="model">bi.profitability.report</field>
        <field name="arch" type="xml">
            <search string="Resumen de rentabilidad">
                <filter name="filter_date" date="date" default_period="month"/>
                <group>
                    <filter string="Fecha" name="groupby_date" context="{'group_by': 'date:day'}"/>
                    <filter string="Compañía" name="groupby_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_bi_profitability_summary_form" model="ir.ui.view">
        <field name="name">bi.profitability.summary.form</field>
        <field name="model">bi.profitability.summary</field>
        <field name="arch" type="xml">
            <form string="IPV" create="false" delete="false" class="o_bi_profitability_summary">
                <header>
                    <button name="action_previous_month" type="object" string="Mes anterior" class="btn-secondary"/>
                    <button name="action_next_month" type="object" string="Mes siguiente" class="btn-secondary"/>
                </header>
                <group>
                    <group>
                        <field name="date_from" widget="daterange" options="{'end_date_field': 'date_to', 'always_range': true}"/>
                        <field name="date_to" invisible="1"/>
                    </group>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <notebook>
                    <page string="Detalle" name="detail">
                        <field name="line_ids" nolabel="1">
                            <list create="false" delete="false" edit="false">
                                <field name="date"/>
                                <field name="sale_amount" sum="Total ventas"/>
                                <field name="product_cost_amount" sum="Total costo de productos"/>
                                <field name="gross_profit_amount" sum="Total margen bruto"/>
                                <field name="currency_id" column_invisible="True"/>
                            </list>
                        </field>
                    </page>
                    <page string="Indicadores" name="indicators">
                        <group>
                            <group string="Totales">
                                <field name="sale_amount"/>
                                <field name="product_cost_amount"/>
                                <field name="other_cost_amount"/>
                                <field name="total_cost_amount"/>
                            </group>
                            <group string="Indicadores globales">
                                <field name="cost_per_sale_pct"/>
                                <field name="total_cost_index_pct"/>
                                <field name="profit_pct"/>
                                <field name="profit_amount"/>
                            </group>
                        </group>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <record id="action_bi_profitability_report" model="ir.actions.act_window">
        <field name="name">Detalle diario de rentabilidad</field>
        <field name="res_model">bi.profitability.report</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_bi_profitability_report_search"/>
        <field name="context">{'search_default_filter_date': 1}</field>
    </record>

    <record id="action_bi_profitability_summary" model="ir.actions.server">
        <field name="name">IPV</field>
        <field name="model_id" ref="model_bi_profitability_summary"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open()</field>
    </record>
</odoo>
